{
  "name": "auto-clear-downloads-extension",
  "version": "1.1.0",
  "description": "A minimal browser extension that removes each download from the history after it finishes.",
  "scripts": {
    "lint": "web-ext lint",
    "start": "web-ext run",
    "build": "web-ext build --overwrite-dest",
    "icons": "node scripts/render-icons.js"
  },
  "webExt": {
    "ignoreFiles": ["icons/icon.svg", "scripts"]
  },
  "keywords": [
    "firefox",
    "chrome",
    "webextension",
    "downloads"
  ],
  "author": "Sander Bongers",
  "license": "MIT",
  "homepage": "https://github.com/sanderbongers/auto-clear-downloads-extension#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanderbongers/auto-clear-downloads-extension.git"
  },
  "bugs": {
    "url": "https://github.com/sanderbongers/auto-clear-downloads-extension/issues"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "sharp": "^0.35.3",
    "web-ext": "^10.4.0"
  }
}
