{
  "manifest_version": 3,
  "name": "Auto-clear Downloads",
  "version": "1.1.0",
  "description": "Removes each download from the history after it finishes.",
  "homepage_url": "https://github.com/sanderbongers/auto-clear-downloads-extension",
  "browser_specific_settings": {
    "gecko": {
      "id": "auto-clear-downloads@bonge.rs",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "minimum_chrome_version": "121",
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["downloads", "history"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  }
}
